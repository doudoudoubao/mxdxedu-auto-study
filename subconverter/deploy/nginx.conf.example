# Nginx 反向代理示例：对外提供 HTTPS，内部转发到本机 25500 端口
#
# 用法：
#   1. 把 sub.example.com 改成你自己的域名（需先把域名解析到 VPS 公网 IP）
#   2. sudo cp deploy/nginx.conf.example /etc/nginx/conf.d/subconverter.conf
#   3. sudo nginx -t && sudo systemctl reload nginx
#   4. 用 certbot 申请证书： sudo certbot --nginx -d sub.example.com
#      （certbot 会自动补全下面注释里的 ssl 配置并设置 80→443 跳转）

server {
    listen 80;
    server_name sub.example.com;

    location / {
        proxy_pass http://127.0.0.1:25500;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # 抓取远程订阅可能较慢，放宽超时
        proxy_read_timeout 60s;
    }
}

